root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,js,json}]
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

# 1TBS brace style: opening brace on same line, else/catch/finally hug closing brace
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false

# Keep single-line members on one line (lambdas, accessors)
csharp_new_line_before_members_in_object_initializers = false
csharp_new_line_before_members_in_anonymous_types = false
csharp_new_line_between_query_expression_clauses = true

# var preference
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:suggestion

# Expression-bodied members (allow when they fit on one line)
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion
csharp_style_expression_bodied_indexers = when_on_single_line:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion

# this. qualifier — only when necessary
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Null checks — modern is null / is not null style
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# using directives outside namespace, system usings first
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_sort_system_directives_first = true

# No primary constructors
csharp_style_prefer_primary_constructors = false:suggestion

[*.{csproj,props,targets}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
