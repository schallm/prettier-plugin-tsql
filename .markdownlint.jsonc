{
  "default": true,

  // line-length — disabled; prose and SQL examples intentionally exceed 80 chars
  "line-length": false,

  // no-duplicate-heading — siblings_only allows the same heading name under
  // different parent sections (e.g. "### Examples" under each ## option,
  // "### SELECT" under both ## DML and an index page)
  "no-duplicate-heading": { "siblings_only": true },

  // no-emphasis-as-heading — disabled; README uses **DML** / **DDL** /
  // **Procedural** / **Security** as bold category labels above feature lists,
  // not as structural headings
  "no-emphasis-as-heading": false
}
