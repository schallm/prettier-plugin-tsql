{
  "name": "prettier-plugin-tsql",
  "version": "0.1.0",
  "description": "Prettier plugin for T-SQL (Microsoft SQL Server) using the official ScriptDom parser",
  "author": "Mike Schall",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schallm/prettier-tsql.git"
  },
  "homepage": "https://github.com/schallm/prettier-tsql#readme",
  "bugs": {
    "url": "https://github.com/schallm/prettier-tsql/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin/dotnet"
  ],
  "keywords": [
    "prettier",
    "prettier-plugin",
    "sql",
    "tsql",
    "t-sql",
    "sqlserver",
    "sql-server",
    "mssql",
    "formatter"
  ],
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "dependencies": {
    "node-api-dotnet": "^0.8.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "scripts": {
    "build:dotnet": "dotnet restore src/dotnet/SqlScriptDom/SqlScriptDom.csproj && dotnet msbuild src/dotnet/SqlScriptDom/SqlScriptDom.csproj /t:Publish /p:Configuration=Release \"/p:PublishDir=../../../bin/dotnet/\"",
    "build:ts": "tsc -p tsconfig.json",
    "build:ts:watch": "tsc -p tsconfig.json --watch",
    "build": "npm run build:dotnet && npm run build:ts",
    "format:ts": "prettier --write \"src/plugin/**/*.ts\"",
    "format:cs": "dotnet format src/dotnet/SqlScriptDom/SqlScriptDom.csproj",
    "format": "npm run format:ts && npm run format:cs",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
