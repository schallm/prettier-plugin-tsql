exports[`fixtures > admin/backup-restore.sql 1`] = `
"backup database AdventureWorks
  to DISK = N'C:\\Backups\\AW_Full.bak'
  with NO_FORMAT = noformat, init, NAME = N'AdventureWorks Full Backup', STATS = 10;

backup database AdventureWorks
  to DISK = N'C:\\Backups\\AW_Full_1.bak',
  DISK = N'C:\\Backups\\AW_Full_2.bak'
  with compression, checksum;

backup log AdventureWorks
  to DISK = N'C:\\Backups\\AW_Log.bak'
  with NO_RECOVERY = norecovery;

restore database AdventureWorks
  from DISK = N'C:\\Backups\\AW_Full.bak'
  with norecovery;

restore database AdventureWorks
  from DISK = N'C:\\Backups\\AW_Full.bak'
  with N'AW_Data' to N'C:\\Data\\AW.mdf', N'AW_Log' to N'C:\\Data\\AW.ldf', recovery, 5;

restore log AdventureWorks
  from DISK = N'C:\\Backups\\AW_Log.bak'
  with recovery;

restore filelistonly
  from DISK = N'C:\\Backups\\AW_Full.bak';

restore headeronly
  from DISK = N'C:\\Backups\\AW_Full.bak';

restore verifyonly
  from DISK = N'C:\\Backups\\AW_Full.bak';

drop database AdventureWorks;

drop database if exists AdventureWorks;

drop database AdventureWorks, AdventureWorksDev;"
`;

