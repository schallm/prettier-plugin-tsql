exports[`CREATE/ALTER TRIGGER > CREATE TRIGGER after insert 1`] = `
"create trigger BooksAfterInsertTrigger
on Books
after insert
as
begin
  update Books
  set Price = Price * 1.1
  where BookId in (
    select BookId
    from inserted
  );
end;
go"
`;

