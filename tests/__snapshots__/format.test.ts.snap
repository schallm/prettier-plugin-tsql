exports[`comment between JOIN clauses > line comment between two joins is preserved on its own line 1`] = `
"select
  b.book_id,
  b.title
from
  dbo.Books as b
  inner join dbo.Authors as a on b.author_id = a.author_id
  -- left join: publishers may not exist for all books
  left join dbo.Publishers as p on b.publisher_id = p.publisher_id;"
`;

exports[`comment between JOIN clauses > multiple comments between joins are all preserved 1`] = `
"select b.book_id
from
  dbo.Books as b
  inner join dbo.Authors as a on b.author_id = a.author_id
  -- optional: genre
  left join dbo.Genres as g on b.genre_id = g.genre_id
  -- optional: publisher
  left join dbo.Publishers as p on b.publisher_id = p.publisher_id;"
`;

