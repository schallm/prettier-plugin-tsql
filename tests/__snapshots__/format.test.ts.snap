`;

exports[`nested join formatting > parenthesized nested join 1`] = `
"select b.title
from
  dbo.Books as b
  left join (
    dbo.Authors as a
    inner join dbo.Publishers as p on a.publisher_id = p.publisher_id
  ) on b.author_id = a.author_id;"
`;

