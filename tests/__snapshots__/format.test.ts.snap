"SELECT TRY_CONVERT(DECIMAL(10,2), Price)
FROM Books;"
`;

exports[`expression functions > TVF in FROM clause 1`] = `
"select *
from GetBooks(1) as b;"
`;

exports[`expression functions > long string concatenation breaks before + not inside function args 1`] = `
"select isnull(VID.LastNm, '') + ', ' + isnull(VID.FirstNm, '') + ' '
+ isnull(VID.MiddleNm, '') + ' ' + isnull(S.Suffix, '') as VisitorNm
from
  Visitors as VID
  inner join Suffixes as S on VID.SuffixId = S.SuffixId;"
`;

exports[`expression functions > short string concatenation stays on one line 1`] = `
"select isnull(LastName, '') + ', ' + isnull(FirstName, '') as FullName
from Authors;"
`;

exports[`intra-WHERE comments > commented-out predicates are preserved between Active predicates 1`] = `
"select BookId
from Books
where
  1 = 1
  and Books.GenreId in (1)
  --and Books.GenreId in (select GenreId from Genres where Name = 'Fiction')
  and Books.PublisherId in (4)
  --and Books.PublisherId in (select PublisherId from Publishers where Country = 'UK')
  and Books.AuthorId in (101, 102);"
`;

exports[`nested join formatting > parenthesized nested join 1`] = `
"select b.Title
from
  Books as b
  left join (
    Authors as a
    inner join Publishers as p on a.PublisherId = p.Id
  ) on b.AuthorId = a.Id;"
`;

exports[`partition functions > ALTER PARTITION FUNCTION MERGE RANGE 1`] = `
"alter partition function pf_date()
  merge range ('2020-01-01');"
`;

exports[`partition functions > ALTER PARTITION FUNCTION SPLIT RANGE 1`] = `
"alter partition function pf_date()
  split range ('2023-01-01');"
`;

exports[`partition functions > CREATE PARTITION FUNCTION RANGE LEFT 1`] = `
"create partition function pf_price (decimal(10,2)) as range left
  for values (100, 500, 1000);"
`;

exports[`partition functions > CREATE PARTITION FUNCTION RANGE RIGHT 1`] = `
"create partition function pf_date (date) as range right
  for values ('2020-01-01', '2021-01-01', '2022-01-01');"
`;

exports[`partition schemes > ALTER PARTITION SCHEME NEXT USED with filegroup 1`] = `
"alter partition scheme ps_date
  next used fg_new;"
`;

exports[`partition schemes > CREATE PARTITION SCHEME 1`] = `
"create partition scheme ps_date
  as partition pf_date
  to ([PRIMARY], fg1, fg2, fg3);"
`;

exports[`partition schemes > CREATE PARTITION SCHEME ALL TO 1`] = `
"create partition scheme ps_date
  as partition pf_date
  all to ([PRIMARY]);"
`;

exports[`sqlCommaStyle: leading > CTE list uses leading commas 1`] = `
"with cte1 as (
  select 1 as x
)
, cte2 as (
  select 2 as y
)
, cte3 as (
  select 3 as z
)
select *
from cte1;"
`;

exports[`sqlCommaStyle: leading > GROUP BY multi-column uses leading commas 1`] = `
"select
  GenreId
  , AuthorId
  , count(*)
from Books
group by
  GenreId
  , AuthorId;"
`;

exports[`sqlCommaStyle: leading > INSERT VALUES multi-row uses leading commas between rows 1`] = `
"insert into Books (
  Title
  , Price
)
values
  (
    'A'
    , 1.00
  )
  , (
    'B'
    , 2.00
  )
  , (
    'C'
    , 3.00
  );"
`;

exports[`sqlCommaStyle: leading > ORDER BY multi-column uses leading commas 1`] = `
"select Id
from Books
order by
  Title asc
  , Price desc
  , AuthorId asc;"
`;

exports[`sqlCommaStyle: leading > SELECT multi-column uses leading commas 1`] = `
"select
  b.BookId
  , b.Title
  , b.Price
from Books as b;"
`;

exports[`sqlCommaStyle: leading > UPDATE SET multi-column uses leading commas 1`] = `
"update Books
set
  Title = @title
  , Price = @price
  , AuthorId = @authorId
where BookId = @id;"
`;

exports[`table hints > NOLOCK on joined table 1`] = `
"select
  b.BookId,
  p.Name
from
  Books as b with (nolock)
  inner join Publishers as p with (nolock) on b.PublisherId = p.Id;"
`;

exports[`table hints > NOLOCK on single table 1`] = `
"select BookId
from Books as b with (nolock);"
`;

exports[`table hints > hints respect keyword case upper 1`] = `
"SELECT BookId
FROM Books WITH (NOLOCK);"
`;

exports[`table hints > multiple hints 1`] = `
"select BookId
from Books with (nolock, rowlock);"
`;
