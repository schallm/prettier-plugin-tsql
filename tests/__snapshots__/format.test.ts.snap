exports[`MERGE statement > MERGE with AND predicate on WHEN MATCHED 1`] = `
"merge into Books as t
using ArchivedBooks as s on t.BookId = s.BookId
when matched and t.Price <> s.Price then
  update set t.Price = s.Price;"
`;

exports[`MERGE statement > MERGE with subquery as source 1`] = `
"merge into Books as t
using (
  select
    BookId,
    Title,
    Price
  from ArchivedBooks
  where Price > 0
) as s on t.BookId = s.BookId
when matched then
  update set
    t.Title = s.Title,
    t.Price = s.Price;"
`;

exports[`MERGE statement > full MERGE with all three clause types 1`] = `
"merge into Books as t
using ArchivedBooks as s on t.BookId = s.BookId
when matched then
  update set
    t.Title = s.Title,
    t.Price = s.Price
when not matched by target then
  insert (BookId, Title, Price)
  values (s.BookId, s.Title, s.Price)
when not matched by source then
  delete;"
`;

