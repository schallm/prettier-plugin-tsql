exports[`SELECT formatting > CTE 1`] = `
"with available_books as (
  select
    book_id,
    title
  from dbo.Books
  where in_stock = 1
)
select b.title
from available_books as b
order by b.title asc;"
`;

exports[`SELECT formatting > GROUP BY CUBE respects keyword case 1`] = `
"SELECT
  genre_id,
  in_stock,
  COUNT(*) AS cnt
FROM dbo.Books
GROUP BY CUBE(genre_id, in_stock);"
`;

exports[`SELECT formatting > GROUP BY ROLLUP respects keyword case 1`] = `
"select
  genre_id,
  author_id,
  sum(price) as total
from dbo.Books
group by rollup(genre_id, author_id);"
`;

exports[`SELECT formatting > SELECT DISTINCT 1`] = `
"select distinct genre_id
from dbo.Books;"
`;

exports[`SELECT formatting > aggregate with GROUP BY / HAVING 1`] = `
"select
  genre_id,
  count(*) as cnt,
  avg(price) as avg_price
from dbo.Books
group by genre_id
having count(*) > 5;"
`;

exports[`SELECT formatting > basic select with join and where 1`] = `
"select
  b.book_id,
  b.title,
  b.price
from
  dbo.Books as b
  inner join dbo.Authors as a on b.author_id = a.author_id
where b.in_stock = 1
order by b.title asc;"
`;

exports[`SELECT formatting > nested CASE in THEN branch indents inner case on new line 1`] = `
"select case
  when ContentType = 'movie' then
    case
      when
        BoxOfficeTotal is null
        or BoxOfficeTotal < 250000000
      then 2.78
      else 3.69
    end
  when ContentType = 'tv-episode' then
    case
      when ContentLength < 30 * 60 then 0.61
      else 0.91
    end
  else -1
end as AgencyCost
from dbo.Content;"
`;

exports[`SELECT formatting > searched CASE with AND condition 1`] = `
"select case
  when
    b.author_id is not null
    and b.genre_id in (1, 2, 3)
  then 1
  else 0
end as IsAvailable
from dbo.Books as b;"
`;

exports[`SELECT formatting > subquery in WHERE 1`] = `
