exports[`OUTPUT clause > MERGE with OUTPUT $action and inserted/deleted columns 1`] = `
"merge into Books as t
using ArchivedBooks as s on t.BookId = s.BookId
when matched then
  update set t.Price = s.Price
when not matched by target then
  insert (BookId, Title, Price)
  values (s.BookId, s.Title, s.Price)
when not matched by source then
  delete
output $action, inserted.BookId, deleted.Price;"
`;

exports[`OUTPUT clause > MERGE with OUTPUT INTO table variable 1`] = `
"merge into Books as t
using ArchivedBooks as s on t.BookId = s.BookId
when matched then
  update set t.Price = s.Price
output
  $action,
  inserted.BookId,
  inserted.Price
into @changes (action, BookId, Price);"
`;

exports[`OUTPUT clause > UPDATE with OUTPUT 1`] = `
