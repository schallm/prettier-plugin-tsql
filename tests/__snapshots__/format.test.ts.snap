exports[`ALTER TABLE formatting > add column 1`] = `
"alter table dbo.Books
add
  isbn nvarchar(20) null;"
`;

exports[`ALTER TABLE formatting > drop column 1`] = `
"alter table dbo.Books
drop column isbn;"
`;

exports[`CREATE PROCEDURE formatting > block comment after last parameter (before AS) stays between params and as 1`] = `
"create procedure dbo.GetBookById
  @id int,
  @active bit
/*WITH ENCRYPTION*/
as
begin
  select book_id
  from dbo.Books
  where book_id = @id;
end;
go"
`;

exports[`CREATE PROCEDURE formatting > block comment between procedure name and first parameter is preserved 1`] = `
"create procedure dbo.GetBookById
/**********************
** Author: Jon
** Date:   2012-01-10
**********************/
  @id int,
  @includeOutOfStock bit = 0
as
begin
  select book_id
  from dbo.Books
  where book_id = @id;
end;
go"
`;

exports[`CREATE PROCEDURE formatting > line comment inside procedure body is preserved 1`] = `
"create procedure dbo.GetAvailableBooks
as
begin
  -- fetch available books only
  select
    book_id,
    title
  from dbo.Books
  where in_stock = 1;
end;
go"
`;

